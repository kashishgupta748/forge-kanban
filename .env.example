# ─── SLACK BOT CONFIGURATION ──────────────────────────────────────────────────
SLACK_APP_TOKEN=xapp-1-placeholder-connections-write-token
SLACK_BOT_TOKEN=xoxb-placeholder-bot-oauth-token
SLACK_WEBHOOK_URL=your_slack_incoming_webhook_url_here
SLACK_CHANNEL_MAIN=#sprint-main
SLACK_CHANNEL_CODER=#agent-coder
SLACK_CHANNEL_LOG=#agent-log

# ─── AI MODELS & API KEYS ─────────────────────────────────────────────────────
# Google AI Studio (Gemini)
GEMINI_API_KEY=AIzaSyPlaceholderGeminiKey

# Groq Console
GROQ_API_KEY=gsk_placeholderGroqConsoleKey

# Local Ollama endpoint
OPENCLAW_OLLAMA_URL=http://localhost:11434

# ─── LARAVEL BACKEND APP CONFIGURATION ────────────────────────────────────────
APP_NAME="Forge Kanban"
APP_ENV=local
APP_KEY=base64:placeholderLaravelKeyGoesHere=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Database configuration
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# ─── FRONTEND REACT CONFIGURATION ─────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
